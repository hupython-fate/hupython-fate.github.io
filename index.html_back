 <!DOCTYPE html>
<html lang="zh-CN">
<!-- 声明文档类型为HTML5，指定语言为简体中文，提升兼容性和SEO -->
<head>
    <!-- 视口设置：适配移动端，宽度=device-width（跟随设备宽度），初始缩放1.0（修复你原拼写错误initai-scale→initial-scale） -->
    <meta name="viewport" content="width=device-width,initial-scale=1.0">
    <!-- 字符编码：UTF-8保证中文等字符正常显示 -->
    <meta charset="utf-8">
    <!-- SEO相关：关键词，提升网站被搜索到的概率 -->
    <meta name="keywords" content="爬虫胡,胡成健,HTML学习,个人网站,代码学习,资源整理">
    <!-- SEO相关：网站描述，搜索结果中展示的简介 -->
    <meta name="description" content="胡成健(爬虫胡)的个人网站，整理了HTML/CSS/JS学习资源、看过的动漫小说、朋友的作品等，帮助自己和他人循序渐进学习。">
    <!-- 作者信息：标注网站开发者 -->
    <meta name="author" content="爬虫胡(hu_cheng_jian)">
    <!-- 自动刷新：5秒后跳转到指定网址（保留原有功能） -->
    <meta name="refresh" content="5;https://huchengjian.dev/">
    <!-- 网页标题：简洁清晰，符合SEO规范 -->
    <title>胡成健的个人网站 | 学习资源与生活整理</title>
    
    <!-- 引入外部CSS样式文件（空元素，无结束标签） -->
    <link rel="stylesheet" type="text/css" href="CSS样式/11_14_样式的转移与link元素.css">
    <!-- 网页图标（favicon）：设置标签页小图标 -->
    <link rel="icon" type="image/x-icon" href="图片/图标2.jpg">
    
    <!-- base标签：统一设置页面中所有链接的默认打开方式为新标签页（仅一个，符合规范） -->
    <base target="_blank">
</head>

<body>
